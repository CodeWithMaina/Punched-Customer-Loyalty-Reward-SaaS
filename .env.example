# ── Docker Environment Variables ─────────────────────────────
# Copy this file to .env and fill in production values.
# docker compose reads .env automatically from the project root.

# Database
DB_PASSWORD=changeme

# JWT (must be at least 32 characters)
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARS_LONG

# SMTP (leave blank to use console logger in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@punched.app